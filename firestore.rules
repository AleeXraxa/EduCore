rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ======================================================
    // §1  IDENTITY & STATUS HELPERS
    // ======================================================

    /** True only when a Firebase Auth token is present. */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Loads the caller's user document.
     * Returns null if the document does not exist (handled by callers).
     */
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /**
     * Validates that the user document exists AND the account is active.
     * Blocked users fail this check immediately.
     */
    function isActiveUser() {
      let u = getUserData();
      return u != null
          && u.keys().hasAll(['role', 'status', 'academyId'])
          && u.status == 'active'
          && u.role in ['super_admin', 'institute_admin', 'staff', 'teacher'];
    }

    // ======================================================
    // §2  ROLE HELPERS  (all gate on isActiveUser first)
    // ======================================================

    function isSuperAdmin() {
      return isSignedIn() && isActiveUser() && getUserData().role == 'super_admin';
    }

    function isInstituteAdmin() {
      return isSignedIn() && isActiveUser() && getUserData().role == 'institute_admin';
    }

    function isStaffOrTeacher() {
      return isSignedIn() && isActiveUser()
          && getUserData().role in ['staff', 'teacher'];
    }

    // ======================================================
    // §3  TENANT & SUBSCRIPTION HELPERS
    // ======================================================

    /**
     * True when the caller's academyId matches the path academyId.
     * Prevents ALL cross-tenant access.
     */
    function belongsTo(academyId) {
      return isSignedIn() && isActiveUser()
          && getUserData().academyId == academyId;
    }

    /** Only institute_admin members of the academy. */
    function isAdminOf(academyId) {
      return isInstituteAdmin() && belongsTo(academyId);
    }

    /** Staff or teacher members of the academy. */
    function isStaffOf(academyId) {
      return isStaffOrTeacher() && belongsTo(academyId);
    }

    /**
     * Verifies that the academy's subscription is active.
     * Expired / pending subscriptions block all writes by non-super_admin.
     */
    function hasActiveSubscription(academyId) {
      return get(/databases/$(database)/documents/subscriptions/$(academyId))
               .data.status == 'active';
    }

    // ======================================================
    // §4  WRITE-SAFETY / FIELD-LEVEL HELPERS
    // ======================================================

    /**
     * Prevents privilege escalation on any role assignment.
     * No one except super_admin may write role == 'super_admin'.
     */
    function roleIsNotSuperAdmin() {
      return request.resource.data.role != 'super_admin';
    }

    /**
     * Guarantees academyId is NEVER changed on an existing document.
     * Critical for multi-tenant immutability.
     */
    function academyIdUnchanged() {
      return request.resource.data.academyId == resource.data.academyId;
    }

    /**
     * Guarantees role is NEVER changed on an existing document
     * unless the caller is super_admin (handled separately).
     */
    function roleUnchanged() {
      return request.resource.data.role == resource.data.role;
    }

    /**
     * Guarantees createdAt is NEVER changed on an existing document.
     */
    function createdAtUnchanged() {
      return !('createdAt' in request.resource.data)
          || request.resource.data.createdAt == resource.data.createdAt;
    }

    // ======================================================
    // §5  GLOBAL DEFAULT — DENY EVERYTHING
    // ======================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ======================================================
    // §6  COLLECTION: users/{uid}
    // ======================================================
    match /users/{uid} {

      // READ
      // ─────
      // • super_admin      → all users
      // • institute_admin  → users in their academy only
      // • self             → own document only
      allow read: if isSuperAdmin()
                  || (isInstituteAdmin() && resource.data.academyId == getUserData().academyId)
                  || (isSignedIn() && isActiveUser() && request.auth.uid == uid);

      // CREATE
      // ──────
      // • super_admin            → anyone, any role
      // • institute_admin        → own academy, any role EXCEPT super_admin
      // Role field must be a recognised value.
      allow create: if isSuperAdmin()
                    || (isAdminOf(request.resource.data.academyId)
                        && roleIsNotSuperAdmin()
                        && request.resource.data.role in ['institute_admin', 'staff', 'teacher']
                        && request.resource.data.status == 'active');

      // UPDATE
      // ──────
      // • super_admin            → full update rights
      // • institute_admin        → own-academy users; cannot change academyId, createdAt,
      //                            or promote to super_admin; cannot demote existing super_admin
      // • self                   → own profile only; role, academyId, createdAt immutable
      allow update: if isSuperAdmin()
                    || (isAdminOf(resource.data.academyId)
                        && resource.data.role != 'super_admin'
                        && roleIsNotSuperAdmin()
                        && academyIdUnchanged()
                        && createdAtUnchanged())
                    || (isSignedIn() && isActiveUser()
                        && request.auth.uid == uid
                        && roleUnchanged()
                        && academyIdUnchanged()
                        && createdAtUnchanged());

      // DELETE
      // ──────
      // Only super_admin may hard-delete user records.
      allow delete: if isSuperAdmin();
    }

    // ======================================================
    // §7  COLLECTION: academies/{academyId}
    // ======================================================
    match /academies/{academyId} {
      // Top-level academy document
      allow read:   if isSuperAdmin() || belongsTo(academyId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();

      // ──────────────────────────────────────────────────
      // SUBCOLLECTION: students/{studentId}
      // ──────────────────────────────────────────────────
      match /students/{studentId} {
        allow read:   if isSuperAdmin() || belongsTo(academyId);
        allow create: if isSuperAdmin()
                      || (isAdminOf(academyId) && hasActiveSubscription(academyId));
        allow update: if isSuperAdmin()
                      || ((isAdminOf(academyId) || isStaffOf(academyId))
                          && hasActiveSubscription(academyId));
        allow delete: if isSuperAdmin()
                      || (isAdminOf(academyId) && hasActiveSubscription(academyId));
      }

      // ──────────────────────────────────────────────────
      // SUBCOLLECTION: fees/{feeId}
      // Payments/fees are finance-sensitive — staff cannot delete
      // ──────────────────────────────────────────────────
      match /fees/{feeId} {
        allow read:   if isSuperAdmin() || belongsTo(academyId);
        allow create: if isSuperAdmin()
                      || (isAdminOf(academyId) && hasActiveSubscription(academyId));
        allow update: if isSuperAdmin()
                      || (isAdminOf(academyId) && hasActiveSubscription(academyId));
        allow delete: if isSuperAdmin();
      }

      // ──────────────────────────────────────────────────
      // SUBCOLLECTION: attendance/{attendanceId}
      // Teachers can mark attendance — limited write (create/update only)
      // ──────────────────────────────────────────────────
      match /attendance/{attendanceId} {
        allow read:   if isSuperAdmin() || belongsTo(academyId);
        allow create: if isSuperAdmin()
                      || ((isAdminOf(academyId) || isStaffOf(academyId))
                          && hasActiveSubscription(academyId));
        allow update: if isSuperAdmin()
                      || ((isAdminOf(academyId) || isStaffOf(academyId))
                          && hasActiveSubscription(academyId));
        allow delete: if isSuperAdmin()
                      || (isAdminOf(academyId) && hasActiveSubscription(academyId));
      }

      // ──────────────────────────────────────────────────
      // SUBCOLLECTION: exams/{examId}
      // Staff can create/update exams; only admin can delete
      // ──────────────────────────────────────────────────
      match /exams/{examId} {
        allow read:   if isSuperAdmin() || belongsTo(academyId);
        allow create: if isSuperAdmin()
                      || ((isAdminOf(academyId) || isStaffOf(academyId))
                          && hasActiveSubscription(academyId));
        allow update: if isSuperAdmin()
                      || ((isAdminOf(academyId) || isStaffOf(academyId))
                          && hasActiveSubscription(academyId));
        allow delete: if isSuperAdmin()
                      || (isAdminOf(academyId) && hasActiveSubscription(academyId));
      }

      // ──────────────────────────────────────────────────
      // SUBCOLLECTION: staff/{staffId}
      // HR records — institute_admin manages; staff cannot self-edit HR records
      // ──────────────────────────────────────────────────
      match /staff/{staffId} {
        allow read:   if isSuperAdmin() || belongsTo(academyId);
        allow create: if isSuperAdmin()
                      || (isAdminOf(academyId) && hasActiveSubscription(academyId));
        allow update: if isSuperAdmin()
                      || (isAdminOf(academyId) && hasActiveSubscription(academyId));
        allow delete: if isSuperAdmin()
                      || (isAdminOf(academyId) && hasActiveSubscription(academyId));
      }
    }

    // ======================================================
    // §8  COLLECTION: subscriptions/{academyId}
    // ======================================================
    match /subscriptions/{academyId} {
      // Institutes may read their own subscription.
      allow read:   if isSuperAdmin() || belongsTo(academyId);
      // Only super_admin writes subscription records.
      // This prevents self-service plan changes or status tampering.
      allow write:  if isSuperAdmin();
    }

    // ======================================================
    // §9  COLLECTIONS: plans & features  (catalogue / read-only)
    // ======================================================
    match /plans/{planId} {
      // Any authenticated & active user may read plan definitions.
      allow read:  if isSignedIn() && isActiveUser();
      allow write: if isSuperAdmin();
    }

    match /features/{featureId} {
      allow read:  if isSignedIn() && isActiveUser();
      allow write: if isSuperAdmin();
    }

    // ======================================================
    // §10  COLLECTION: payments/{paymentId}
    // ======================================================
    match /payments/{paymentId} {
      // READ: super_admin sees all; institute user sees only their academy's records.
      allow read: if isSuperAdmin()
                  || (belongsTo(resource.data.academyId));

      // CREATE: institute_admin may submit a payment request.
      //         Institutes cannot pre-set status to anything other than 'pending'.
      //         super_admin can create freely.
      allow create: if isSuperAdmin()
                    || (isAdminOf(request.resource.data.academyId)
                        && request.resource.data.status == 'pending');

      // UPDATE: ONLY super_admin may update (approve / reject / reconcile).
      //         Institute users must NEVER be able to modify payment status.
      allow update: if isSuperAdmin();

      // DELETE: ONLY super_admin.
      allow delete: if isSuperAdmin();
    }

    // ======================================================
    // §11  COLLECTION: auditLogs/{logId}
    // ======================================================
    match /auditLogs/{logId} {
      // Only super_admin may read the audit trail.
      allow read:   if isSuperAdmin();
      // Writes are handled by Cloud Functions using the Admin SDK,
      // which bypasses these rules. Client-side writes are denied.
      allow write:  if isSuperAdmin();
    }
    // ======================================================
    // §12  COLLECTION: notifications/{notificationId}
    // ======================================================
    match /notifications/{notificationId} {
      // Only super_admin may read and write notifications.
      // This is a platform-broadcast collection; institute users have no access.
      allow read:   if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ======================================================
    // §13  COLLECTION: settings/{docId}
    // ======================================================
    match /settings/{docId} {
      // Any active authenticated user may read settings (needed for sidebar branding, app name, logo).
      // Only super_admin may write (update platform-wide configuration).
      allow read:  if isSignedIn() && isActiveUser();
      allow write: if isSuperAdmin();
    }
  }
}
